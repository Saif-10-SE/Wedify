# Copy this file to ".env.local" and fill in real keys.
# Next.js only loads .env.local / .env — NOT .env.example

# MongoDB Atlas connection string (Option A backend)
# Example: mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/wedify?retryWrites=true&w=majority
# If empty, APIs fall back to local JSON files in data/store/
MONGODB_URI=

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image-preview

# Decor images: OpenAI GPT Image models (primary when set)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_IMAGE_MODELS=gpt-image-1.5,gpt-image-1
